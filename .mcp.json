{
  "name": "translation-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Sovereign AI tools for everyone.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "translate_text",
      "description": "Translate text between languages using built-in dictionary and word mapping.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "source_language": {
            "type": "string"
          },
          "target_language": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "detect_language",
      "description": "Detect the language of input text using script and word analysis.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "detailed": {
            "type": "boolean"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "check_grammar",
      "description": "Check text for common grammar and style issues.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "adjust_tone",
      "description": "Analyze text tone and provide recommendations for adjustment.",
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "target_tone": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    {
      "name": "validate_localization",
      "description": "Validate localized strings for common internationalization issues.",
      "parameters": {
        "type": "object",
        "properties": {
          "strings": {
            "type": "array"
          },
          "target_locale": {
            "type": "string"
          }
        },
        "required": [
          "strings"
        ]
      }
    }
  ]
}